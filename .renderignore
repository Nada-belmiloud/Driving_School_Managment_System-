# Files and directories to exclude from Render deployment
# This helps reduce build time and deploy size

# Documentation files (not needed in production)
*.md
docs/
DASHBOARD*.md

# Git files
.git/
.gitignore
.gitattributes

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Test files
tests/
**/__tests__/
*.test.js
*.spec.js

# Development dependencies
node_modules/

# Local environment files (use Render dashboard for env vars)
.env
.env.local
.env.*.local

# Build artifacts (will be rebuilt on Render)
.next/
dist/
build/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Temporary files
tmp/
temp/
*.tmp
